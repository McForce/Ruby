<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Custom</authenticationProtocol>
    <label>BB C360 Data Cloud</label>
    <!--
        Auth is performed in Apex (BB_C360_DataCloud_IH_v1 does the Data Cloud
        token exchange and sets the Authorization header itself). No framework
        auth flow is configured here. The named credential must have
        generateAuthorizationHeader = false so the Apex-set header is preserved.
    -->
    <externalCredentialParameters>
        <parameterGroup>Data Graph</parameterGroup>
        <parameterName>Data Graph</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
